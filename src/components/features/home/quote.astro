---
import { Button } from "@/components/ui/button";
import { FadeContent } from "@/components/ui/fade-content";
import { PhoneInputField } from "@/components/ui/phone-input-field";
import SectionTitle from "@/components/ui/section-title.astro";
import SectionDescription from "@/components/ui/section-description.astro";
---

<section id="devis" class="relative overflow-hidden border-t border-border/60 py-16 sm:py-20 lg:py-28">
  <div
    class="absolute inset-0 opacity-[0.03]"
    style="background-image: 
      linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px);
      background-size: 48px 48px;"
  />

  <div class="relative mx-auto max-w-6xl px-5 sm:px-6 lg:px-8">
    <div class="mx-auto mb-12 max-w-2xl text-center lg:mb-16">
      <FadeContent client:visible>
        <SectionTitle eyebrow="évaluation privée">
          Demander une évaluation privée
        </SectionTitle>
        <SectionDescription>
          Nous vous répondons sous 48h, sans engagement.
        </SectionDescription>
      </FadeContent>
    </div>

    <FadeContent client:visible delay={150}>
      <div class="mx-auto max-w-lg">
        <form
          action="/merci"
          name="devis"
          method="post"
          netlify
          class="space-y-6"
        >
          <p style="display:none">
            <label>Don't fill this out if you're human: <input name="bot-field" /></label>
          </p>

          <div class="space-y-3">
            <label for="name" class="text-sm font-medium text-foreground/80">
              Nom <span class="text-red-500/80">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              placeholder="Votre nom"
              required
              class="block w-full rounded-xl border border-foreground/10 bg-card/50 px-4 py-3 text-sm text-foreground placeholder:text-foreground/25 transition-all duration-300 focus:border-foreground/30 focus:outline-none focus:ring-0"
            />
          </div>

          <div class="space-y-3">
            <label for="email" class="text-sm font-medium text-foreground/80">
              Email <span class="text-red-500/80">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="mail@exemple.com"
              required
              class="block w-full rounded-xl border border-foreground/10 bg-card/50 px-4 py-3 text-sm text-foreground placeholder:text-foreground/25 transition-all duration-300 focus:border-foreground/30 focus:outline-none focus:ring-0"
            />
          </div>

          <div class="space-y-3">
            <label for="phone" class="text-sm font-medium text-foreground/80">
              Téléphone <span class="text-red-500/80">*</span>
            </label>
            <input type="hidden" name="phone" id="phone-hidden" />
            <PhoneInputField required client:load />
          </div>

          <div class="space-y-3">
            <label for="message" class="text-sm font-medium text-foreground/80">
              Description du projet <span class="text-red-500/80">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              placeholder="Parlez-nous de votre établissement et de vos besoins…"
              required
              rows={5}
              class="block w-full resize-none rounded-xl border border-foreground/10 bg-card/50 px-4 py-3 text-sm text-foreground placeholder:text-foreground/25 transition-all duration-300 focus:border-foreground/30 focus:outline-none focus:ring-0"
            ></textarea>
          </div>

          <Button type="submit" variant="glow" size="lg" class="w-full">
            Envoyer ma demande
          </Button>
        </form>
      </div>
    </FadeContent>
  </div>
</section>

<style is:global>
  .phone-input-wrapper {
    display: flex !important;
    align-items: center !important;
    width: 100% !important;
    border-radius: 0.75rem !important;
    border: 1px solid color-mix(in oklab, var(--foreground) 10%, transparent) !important;
    background-color: color-mix(in oklab, var(--card) 50%, transparent) !important;
    padding: 0.625rem 1rem !important;
    transition: all 0.3s !important;
  }

  .phone-input-wrapper:focus-within {
    border-color: color-mix(in oklab, var(--foreground) 30%, transparent) !important;
  }

  .phone-input-wrapper .PhoneInputInput {
    border: none !important;
    background: transparent !important;
    font-size: 0.875rem !important;
    color: var(--foreground) !important;
    outline: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
    min-width: 0 !important;
  }

  .phone-input-wrapper .PhoneInputInput::placeholder {
    color: color-mix(in oklab, var(--foreground) 25%, transparent) !important;
  }

  .phone-input-wrapper .PhoneInputCountry {
    margin-right: 0.5rem !important;
  }

  .phone-input-wrapper .PhoneInputCountrySelect {
    color: var(--foreground) !important;
    background: var(--card) !important;
    color-scheme: light dark !important;
  }

  .phone-input-wrapper .PhoneInputCountrySelectArrow {
    opacity: 0.45 !important;
    color: var(--foreground) !important;
  }
</style>
